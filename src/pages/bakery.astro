---
import BaseLayout from "../layouts/BaseLayout.astro";
import Carousel from "../components/react/Carousel";
import { getImage, Image } from "astro:assets";
import { generateLqip } from "../utils/lqip";
import { readFile } from "node:fs/promises";
import { join } from "node:path";

import bakeryLeft1 from "../assets/images/bakery-images/left-image-1.webp";
import bakeryLeft2 from "../assets/images/bakery-images/left-image-2.webp";
import bakeryRight1 from "../assets/images/bakery-images/right-image-1.webp";
import pattern from "../assets/textures_and_borders/pattern.webp";

import b1 from "../assets/images/bakery-carousel/desktop/bakery-1.webp";
import b2 from "../assets/images/bakery-carousel/desktop/bakery-2.webp";
import b3 from "../assets/images/bakery-carousel/desktop/bakery-3.webp";
import b4 from "../assets/images/bakery-carousel/desktop/bakery-4.webp";

import b1m from "../assets/images/bakery-carousel/mobile/bakery-1-mobile.webp";
import b2m from "../assets/images/bakery-carousel/mobile/bakery-2-mobile.webp";
import b3m from "../assets/images/bakery-carousel/mobile/bakery-3-mobile.webp";
import b4m from "../assets/images/bakery-carousel/mobile/bakery-4-mobile.webp";

const [img1, img2, img3, img4, mob1, mob2, mob3, mob4] = await Promise.all([
    getImage({ src: b1, format: "webp" }),
    getImage({ src: b2, format: "webp" }),
    getImage({ src: b3, format: "webp" }),
    getImage({ src: b4, format: "webp" }),
    getImage({ src: b1m, format: "webp" }),
    getImage({ src: b2m, format: "webp" }),
    getImage({ src: b3m, format: "webp" }),
    getImage({ src: b4m, format: "webp" }),
]);

const [lqipDesktop, lqipMobile] = await Promise.all([
    generateLqip(
        await readFile(
            join(
                process.cwd(),
                "src/assets/images/bakery-carousel/desktop/bakery-1.webp",
            ),
        ),
    ),
    generateLqip(
        await readFile(
            join(
                process.cwd(),
                "src/assets/images/bakery-carousel/mobile/bakery-1-mobile.webp",
            ),
        ),
    ),
]);

const bakeryCarouselImages = [
    {
        src: img1.src,
        lqip: lqipDesktop,
        mobileSrc: mob1.src,
        mobileLqip: lqipMobile,
        alt: "OBC Bakery",
    },
    {
        src: img2.src,
        lqip: lqipDesktop,
        mobileSrc: mob2.src,
        alt: "OBC Bakery",
    },
    {
        src: img3.src,
        lqip: lqipDesktop,
        mobileSrc: mob3.src,
        alt: "OBC Bakery",
    },
    {
        src: img4.src,
        lqip: lqipDesktop,
        mobileSrc: mob4.src,
        alt: "OBC Bakery",
    },
];
---

<BaseLayout
    title="Bakery"
    description="OBC Bakery — fresh-baked bread, pastries and hot foods at select OBC Better Butchery stores nationwide."
>
    <div class="sticky top-0 w-full z-0">
        <Carousel client:load images={bakeryCarouselImages} />
    </div>

    <div class="relative z-20 bg-brand-bg">
        <div class="w-full overflow-hidden leading-none">
            <Image
                src={pattern}
                alt=""
                aria-hidden="true"
                class="w-full h-auto block"
                loading="eager"
            />
        </div>

        <section id="liquor-content" class="w-full bg-brand-bg">
            <div class="max-w-7xl mx-auto py-16 px-6 md:px-12 lg:px-16">
                <div class="mb-14 md:mb-20">
                    <p
                        class="text-brand-dark uppercase tracking-[0.2em] text-sm font-sans heading-small font-semibold mb-3"
                    >
                        bakery
                    </p>
                    <h1
                        class="text-4xl md:text-5xl lg:text-6xl font-sans font-bold text-brand-dark leading-tight"
                    >
                        Quality, Fresh<br />&amp; your better choice
                    </h1>
                </div>

                <!-- Row 1: Image Left (circle + parallax pancakes), Text Right -->
                <div
                    class="flex flex-col md:flex-row items-center gap-10 md:gap-16 mb-24 md:mb-32"
                >
                    <!-- Left: Bakery storefront -->
                    <div
                        class="w-full md:w-1/2 relative flex justify-center md:justify-start"
                    >
                        <!-- Large circle -->
                        <div class="relative w-full max-w-[460px]">
                            <div
                                class="aspect-square rounded-full overflow-hidden zoom-circle"
                            >
                                <Image
                                    src={bakeryLeft1}
                                    alt="OBC Bakery Storefront"
                                    class="zoom-circle-img w-full h-full object-cover"
                                    width={920}
                                    height={920}
                                    loading="lazy"
                                />
                            </div>
                            <!-- Parallax pancakes image — overlaps bottom-left of the circle -->
                            <div
                                class="absolute -bottom-24 -left-16 md:-bottom-32 md:-left-24 w-72 md:w-96 lg:w-[420px] drop-shadow-2xl overflow:hidden pointer-events-none"
                                id="parallax-pancakes"
                            >
                                <Image
                                    src={bakeryLeft2}
                                    alt="Pancakes with blueberries"
                                    class="w-full h-auto"
                                    loading="lazy"
                                />
                            </div>
                        </div>
                    </div>

                    <!-- Right: text -->
                    <div
                        class="w-full md:w-1/2 font-sans text-brand-dark space-y-5 text-[15px] md:text-base leading-relaxed md:pl-8 lg:pl-12"
                    >
                        <p>
                            Step into the cozy warmth of our bakery sections and
                            treat yourself to a selection of freshly baked
                            goods, lovingly prepared each day. Whether it's
                            standalone bakeries or in-store bakery corners, we
                            offer a modest yet delightful range of cakes,
                            muffins, cupcakes, and more, catering to the tastes
                            of our valued customers in South Africa. Our bakery
                            may be small in size, but it's big on flavour and
                            freshness, quickly becoming a beloved spot for those
                            seeking affordable indulgences.
                        </p>
                    </div>
                </div>

                <!-- ── Row 2: Text Left, Single Circle Right ──────────── -->
                <div
                    class="flex flex-col-reverse md:flex-row items-center gap-10 md:gap-16 pb-20"
                >
                    <!-- Left: text -->
                    <div
                        class="w-full md:w-1/2 font-sans text-brand-dark space-y-5 text-[15px] md:text-base leading-relaxed md:pr-8 lg:pr-12"
                    >
                        <p>
                            Looking ahead, we're expanding our bakery offerings
                            to additional stores in the future, with plans to
                            bring the convenience of freshly baked goods to more
                            communities. If you're wondering whether your local
                            store offers these tasty treats, simply check our
                            website's store finder for up-to-date information.
                            Join us at our bakery corners, where simplicity
                            meets satisfaction, and every bite brings a moment
                            of joy without breaking the bank.
                        </p>
                    </div>

                    <!-- Right: single circle -->
                    <div
                        class="w-full md:w-1/2 relative flex justify-center md:justify-end"
                    >
                        <div class="relative w-full max-w-[460px]">
                            <!-- Large circle — bakery treats display -->
                            <div
                                class="aspect-square rounded-full overflow-hidden zoom-circle"
                            >
                                <Image
                                    src={bakeryRight1}
                                    alt="OBC Bakery store display"
                                    class="zoom-circle-img w-full h-full object-cover"
                                    width={920}
                                    height={920}
                                    loading="lazy"
                                />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Scrolling Marquee -->
            <div class="w-full overflow-hidden py-4 bg-brand-bg">
                <div class="marquee-track flex gap-12 whitespace-nowrap">
                    {
                        Array.from({ length: 8 }).map(() => (
                            <span class="marquee-item inline-flex gap-12 shrink-0 text-brand-primary font-sans font-black uppercase text-3xl md:text-4xl tracking-widest">
                                <span>QUALITY</span>
                                <span>CONVENIENCE</span>
                                <span>AFFORDABILITY</span>
                            </span>
                        ))
                    }
                </div>
            </div>

            <!--CTA Buttons -->
            <div
                class="flex flex-col sm:flex-row items-center justify-center gap-4 py-14 px-6 bg-brand-bg"
            >
                <a
                    id="btn-store-finder"
                    href="/store-finder"
                    class="btn-outline bg-brand-primary text-brand-light font-bold text-sm px-8 py-3 rounded-full border-brand-primary uppercase tracking-widest"
                >
                    Store Finder
                </a>
                <a
                    id="btn-join-our-team"
                    href="https://obc.co.za/wp-content/uploads/2024/06/OBC-Introduction-2024-June-LR.pdf"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="btn-outline bg-brand-primary text-brand-light font-bold text-sm px-8 py-3 rounded-full border-brand-primary uppercase tracking-widest"
                >
                    Join Our Team
                </a>
            </div>

            <!-- Bottom divider -->
            <div class="w-full overflow-hidden leading-none rotate-180">
                <Image
                    src={pattern}
                    alt=""
                    aria-hidden="true"
                    class="w-full h-auto block"
                    loading="lazy"
                />
            </div>
        </section>
    </div>

    <script>
        import gsap from "gsap";
        import { ScrollTrigger } from "gsap/ScrollTrigger";

        gsap.registerPlugin(ScrollTrigger);

        function init() {
            if (!document.querySelector("#parallax-pancakes")) return;

            gsap.to("#parallax-pancakes", {
                y: -120,
                ease: "none",
                scrollTrigger: {
                    trigger: "#parallax-pancakes",
                    start: "top bottom",
                    end: "bottom top",
                    scrub: true,
                },
            });

            document.querySelectorAll(".zoom-circle").forEach((circle) => {
                const img = circle.querySelector(".zoom-circle-img");

                if (!img) return;

                gsap.fromTo(
                    img,
                    { scale: 1.2 },
                    {
                        scale: 1.0,
                        ease: "none",
                        scrollTrigger: {
                            trigger: circle,
                            start: "top bottom",
                            end: "bottom top",
                            scrub: true,
                        },
                    },
                );
            });

            ScrollTrigger.refresh();
        }

        // ASTRO bug prevention
        document.addEventListener("astro:before-swap", () => {
            ScrollTrigger.getAll().forEach((trigger) => trigger.kill());
        });

        document.addEventListener("astro:page-load", init);
    </script>
</BaseLayout>

<style>
    .marquee-track {
        animation: marquee-scroll 28s linear infinite;
        will-change: transform;
    }

    @keyframes marquee-scroll {
        from {
            transform: translateX(0);
        }
        to {
            transform: translateX(-50%);
        }
    }
    .zoom-circle-img {
        transform: scale(1.2);
        transform-origin: center center;
    }
</style>
