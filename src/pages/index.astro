---
import BaseLayout from "../layouts/BaseLayout.astro";
import Carousel from "../components/react/Carousel";
import ScatterGallery from "../components/react/ScatterGallery";
import type { ScatterImage } from "../components/react/ScatterGallery";
import type { ImageMetadata } from "astro";
import DepartmentCards from "../components/sections/DepartmentCards.astro";
import DepartmentIcons from "../components/sections/DepartmentIcons.astro";
import BlockmansDenPreview from "../components/sections/BlockmansDenPreview.astro";
// import FacebookFeed from "../components/sections/FacebookFeed.astro";
import { getImage, Picture, Image } from "astro:assets";
import { generateLqip } from "../utils/lqip";
import { readFile } from "node:fs/promises";
import { join } from "node:path";

import h1 from "../assets/images/home-page/home-page-carousel/home-carousel-1.webp";
import h2 from "../assets/images/home-page/home-page-carousel/home-carousel-2.webp";
import h3 from "../assets/images/home-page/home-page-carousel/home-carousel-3.webp";
import h1Mobile from "../assets/images/home-page/home-page-carousel/home-carousel-1-mobile.webp";
import h2Mobile from "../assets/images/home-page/home-page-carousel/home-carousel-2-mobile.webp";
import h3Mobile from "../assets/images/home-page/home-page-carousel/home-carousel-3-mobile.webp";
import tholaZonkeImport from "../assets/images/home-page/thola-zonke-banner.webp";
import tholaZonkeMobileImport from "../assets/images/home-page/thola-zonke-banner-mobile.webp";
import heroMobile from "../assets/images/home-page/hero-mobile.webp";
import patternDiagonalImg from "../assets/images/hero-images/pattern-diagonal.svg";
import spicesImg from "../assets/images/hero-images/spice.png";
import grinderImg from "../assets/images/hero-images/pepper-grinder.png";
import worsImg from "../assets/images/hero-images/wors-and-cloth.png";
import pattern from "../assets/textures_and_borders/pattern.webp";
import butcherySpecialsImg from "../assets/images/home-page/image-cards/butchery-specials.webp";
import liquorSpecialsImg from "../assets/images/home-page/image-cards/liquor-specials.webp";
import storeFinderImg from "../assets/images/home-page/image-cards/store-finder.webp";

// -- Step 2: Astro image pipeline ----------------------------------------------
const [img1, img2, img3] = await Promise.all([
  getImage({ src: h1, format: "webp" }),
  getImage({ src: h2, format: "webp" }),
  getImage({ src: h3, format: "webp" }),
]);

const [tholaZonke, tholaZonkeMobile] = await Promise.all([
  getImage({ src: tholaZonkeImport, format: "webp" }),
  getImage({ src: tholaZonkeMobileImport, format: "webp" }),
]);

// process.cwd() is used here instead of a relative path — relative paths break
// in the Astro build context because prerendered pages run from dist/, not src/
const lqipDesktop = await generateLqip(
  await readFile(
    join(
      process.cwd(),
      "src/assets/images/home-page/home-page-carousel/home-carousel-1.webp",
    ),
  ),
);

const lqipMobile = await generateLqip(
  await readFile(
    join(
      process.cwd(),
      "src/assets/images/home-page/home-page-carousel/home-carousel-1-mobile.webp",
    ),
  ),
);

const tholaZonkeLqip = await generateLqip(
  await readFile(
    join(process.cwd(), "src/assets/images/home-page/thola-zonke-banner.webp"),
  ),
);

const tholaZonkeMobileLqip = await generateLqip(
  await readFile(
    join(
      process.cwd(),
      "src/assets/images/home-page/thola-zonke-banner-mobile.webp",
    ),
  ),
);

const homeCarouselImages = [
  {
    src: img1.src,
    lqip: lqipDesktop,
    mobileSrc: h1Mobile.src,
    mobileLqip: lqipMobile,
    alt: "OBC Group",
  },
  {
    src: img2.src,
    lqip: lqipDesktop,
    mobileSrc: h2Mobile.src,
    mobileLqip: lqipMobile,
    alt: "OBC Group",
  },
  {
    src: img3.src,
    lqip: lqipDesktop,
    mobileSrc: h3Mobile.src,
    mobileLqip: lqipMobile,
    alt: "OBC Group",
  },
];

const tholaZonkeImage = [
  {
    src: tholaZonke.src,
    lqip: tholaZonkeLqip,
    mobileSrc: tholaZonkeMobile.src,
    mobileLqip: tholaZonkeMobileLqip,
    alt: "Thola Zonke Rewards Banner",
  },
];

const scatterImagesRaw_ = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/images/home-page/scatter-gallery/*.{jpeg,jpg,png,webp,avif}",
  { eager: true },
);
const scatterImagesRaw = Object.entries(scatterImagesRaw_)
  .sort(([pathA], [pathB]) => {
    const matchA = pathA.match(/img-(\d+)/);
    const matchB = pathB.match(/img-(\d+)/);
    if (matchA && matchB) return parseInt(matchA[1]) - parseInt(matchB[1]);
    return pathA.localeCompare(pathB);
  })
  .map(([path, module]) => module.default);

const processedScatterImages: ScatterImage[] = await Promise.all(
  scatterImagesRaw.map(async (img, idx) => {
    const isAnchor = idx === 0;
    const mobw = isAnchor ? 640 : 300;
    const tabw = isAnchor ? 1024 : 400;
    const desw = isAnchor ? 1920 : 700;

    const m = await getImage({ src: img, width: mobw, format: "webp" });
    const t = await getImage({ src: img, width: tabw, format: "webp" });
    const d = await getImage({ src: img, width: desw, format: "webp" });

    return {
      src: d.src,
      srcSet: `${m.src} 640w, ${t.src} 1024w, ${d.src} 1920w`,
      sizes: "100vw",
      alt: `Scatter Image ${idx}`,
    };
  }),
);

const anchorImage = processedScatterImages[0];
const scatterImages = processedScatterImages.slice(1);
---

<BaseLayout title="Home" description="Your Better Butchery">
  <div id="home-page" class="relative w-full bg-brand-bg">
    <!-- Responsive Layered Hero -->
    <section
      class="hero-wrapper relative w-full h-auto min-h-auto lg:h-[clamp(calc(80vh),120vh,120vh)] md:h-[80vh] overflow-hidden bg-brand-bg flex flex-col items-center pt-32 pb-0 md:pt-60"
    >
      <!-- The Angled SVG Pattern Backdrop -->
      <div
        class="absolute inset-0 z-0 flex hidden md:flex items-center justify-center opacity-100 pointer-events-none overflow-hidden"
      >
        <img
          src={patternDiagonalImg.src}
          alt=""
          class="w-full h-full object-cover scale-[1.02] pattern-bg opacity-0"
        />
      </div>

      <!-- Typography Constraints (matches current sizing and keeps it left) -->
      <div
        class="relative z-30 w-full px-6 md:pl-12 lg:pl-28 xl:pl-[12%] max-w-[1920px] mx-auto h-full flex flex-col md:justify-center pointer-events-none md:pt-12"
      >
        <!-- Text block -->
        <div
          class="hero-text-layer w-full lg:w-[65%] flex flex-col items-center md:items-start -mt-[calc(20%+10px)] space-y-4 md:space-y-6 pointer-events-auto opacity-0"
        >
          <h1
            class="text-brand-dark font-sans font-bold uppercase mt-40 md:mt-2 p-0 tracking-wide leading-[0.9] text-[clamp(4rem,8vw,10.5rem)] text-center md:text-left"
          >
            <span class="font-normal tracking-[-0.02em]">The</span><br
            />Obvi'yass<br />
            <span class="text-brand-primary font-black">Better</span><br />
            <span class="text-brand-primary font-black">Choice</span><span
              class="text-brand-dark">.</span
            >
          </h1>
        </div>

        <!-- MOBILE IMAGE (Art Direction) - Only visible on sm/mobile -->
        <div
          class="relative w-[calc(100%+3rem)] -mx-6 mt-16 md:hidden h-auto pointer-events-none mt-auto opacity-0 hero-mobile-layer"
        >
          <Picture
            src={heroMobile}
            alt="OBC Group Braai Nation Mobile"
            class="w-full h-auto object-cover object-top drop-shadow-2xl block"
            loading="eager"
            fetchpriority="high"
            formats={["avif", "webp"]}
            widths={[400, 768]}
            sizes="100vw"
          />
        </div>
      </div>

      <!--Absolute Image Layers tied to Viewport (Desktop ONLY) -->
      <div
        class="hidden md:block absolute inset-0 w-full h-full pointer-events-none z-20 max-w-[1920px] mx-auto"
      >
        <!-- Spices Layer -->
        <div
          class="hero-spices-layer absolute md:bottom-[20%] md:right-[12%] md:w-[50%] lg:w-[45%] z-30 opacity-0 -translate-y-8"
        >
          <Picture
            src={spicesImg}
            alt="OBC Spices"
            loading="eager"
            fetchpriority="high"
            formats={["avif", "webp"]}
            widths={[400, 800]}
            sizes="(min-width: 1024px) 42vw, 45vw"
            class="w-full h-auto object-contain"
          />
        </div>

        <!-- Pepper Grinder Layer -->
        <div
          class="hero-grinder-layer absolute md:bottom-[50%] md:right-[0%] md:w-[32%] lg:w-[24%] z-20 opacity-0 translate-y-8"
        >
          <Picture
            src={grinderImg}
            alt="OBC Pepper Grinder"
            loading="eager"
            fetchpriority="high"
            formats={["avif", "webp"]}
            widths={[200, 400]}
            sizes="(min-width: 1024px) 20vw, 35vw"
            class="w-full h-auto object-contain"
          />
        </div>

        <!-- Wors Layer (Anchored bottom right) -->
        <div
          class="hero-wors-layer absolute md:bottom-[0] lg:bottom-[clamp(-10%,0%,10%)] md:right-[2%] lg:right-[4%] md:w-[60%] lg:w-[50%] z-10 opacity-0 translate-y-12 origin-bottom-right"
        >
          <Picture
            src={worsImg}
            alt="OBC Wors"
            loading="eager"
            fetchpriority="high"
            formats={["avif", "webp"]}
            widths={[600, 1200]}
            sizes="(min-width: 1024px) 60vw, 95vw"
            class="w-full h-auto object-contain"
          />
        </div>
      </div>
    </section>

    <script>
      import { gsap } from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";
      import { SplitText } from "gsap/SplitText";

      gsap.registerPlugin(ScrollTrigger, SplitText);

      let heroCtx: ReturnType<typeof gsap.context> | null;

      function initHeroAnimations() {
        if (!document.getElementById("home-page")) return;

        requestAnimationFrame(() => {
          if (!document.getElementById("home-page")) return; // Safe check if navigated away

          if (heroCtx) {
            heroCtx.revert();
            heroCtx = null;
          }

          heroCtx = gsap.context(() => {
            // SplitText masked line reveal
            SplitText.create(".hero-text-layer h1", {
              type: "lines",
              mask: "lines",
              autoSplit: true,
              onSplit: (self) => {
                gsap.set(".hero-text-layer", { opacity: 1, y: 0 });
                return gsap.from(self.lines, {
                  yPercent: 120,
                  duration: 1.2,
                  ease: "expo.out",
                  stagger: 0.05,
                  delay: 0.8,
                });
              },
            });

            // Entry Timeline
            const tl = gsap.timeline({ defaults: { ease: "power3.out" } });

            tl.to(".pattern-bg", { opacity: 0.8, duration: 1.5 })
              .to(
                ".hero-mobile-layer",
                { opacity: 1, y: 0, duration: 0.8 },
                "-=1.0",
              )
              .to(
                ".hero-wors-layer",
                { opacity: 1, y: 0, duration: 0.9 },
                "-=0.8",
              )
              .to(
                ".hero-grinder-layer",
                { opacity: 1, y: 0, duration: 0.8 },
                "-=0.7",
              )
              .to(
                ".hero-spices-layer",
                { opacity: 1, y: 0, duration: 0.5 },
                "-=0.9",
              );

            // Subtle Parallax Scroll Interactions
            gsap.to(".hero-spices-layer", {
              yPercent: -15,
              ease: "none",
              scrollTrigger: {
                trigger: ".hero-wrapper",
                start: "top top",
                end: "bottom top",
                scrub: true,
              },
            });

            gsap.to(".hero-grinder-layer", {
              yPercent: -25,
              rotation: 10,
              ease: "none",
              scrollTrigger: {
                trigger: ".hero-wrapper",
                start: "top top",
                end: "bottom top",
                scrub: true,
              },
            });

            const highlightText = document.querySelector("#highlight-text");
            if (highlightText) {
              if ((highlightText as any)._split) {
                (highlightText as any)._split.revert();
              }

              const splitHighlight = new SplitText(highlightText, {
                type: "lines",
              });
              (highlightText as any)._split = splitHighlight;

              const masks: HTMLElement[] = [];
              splitHighlight.lines.forEach((line) => {
                line.style.position = "relative";

                const mask = document.createElement("span");
                mask.className =
                  "absolute top-0 left-0 w-full h-[115%] bg-brand-bg opacity-[0.85] z-10 origin-left scale-x-0 pointer-events-none";
                line.appendChild(mask);
                masks.push(mask);
              });

              gsap.to(masks, {
                scaleX: 1,
                ease: "none",
                duration: 1,
                stagger: 1,
                scrollTrigger: {
                  trigger: highlightText,
                  start: "top 75%",
                  end: "bottom 45%",
                  scrub: true,
                },
              });
            }
          });
        });
      }

      document.addEventListener("astro:page-load", initHeroAnimations);

      document.addEventListener("astro:before-swap", () => {
        if (heroCtx) {
          heroCtx.revert();
          heroCtx = null;
        }
      });
    </script>
    <!-- Thin pattern -->
    <div class="w-full overflow-hidden leading-none">
      <Image
        src={pattern}
        alt=""
        aria-hidden="true"
        class="w-full h-auto block"
        loading="eager"
      />
    </div>
    <!-- Join our team - franchisee button -->
    <div
      class="bg-[#181818] flex pt-6 pb-6 justify-center text-center items-center"
    >
      <div>
        <p
          class="small-heading uppercase text-center md:pr-6 lg:pr-12 block md:inline-block text-brand-light py-6"
        >
          View our franchisee application & join our team
        </p>
        <a
          href="/pdfs/obc-franchisee-info.pdf"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-outline card-btn inline-flex before:bg-[#181818] items-center justify-center bg-brand-primary text-brand-light font-bold md:px-5 md:py-3 rounded-full hover:bg-brand-primary border-brand-primary transition-colors uppercase tracking-widest pointer-events-auto text-[clamp(0.75rem,0.9vw,0.95rem)]"
        >
          Join Our Team
        </a>
      </div>
    </div>
    <!-- Sticky Carousel -->
    <div class="sticky top-0 w-full z-0">
      <Carousel client:load images={homeCarouselImages} />
    </div>
    <!--  Rest of the Page Content -->
    <div class="relative z-20 bg-brand-bg min-h-screen pt-[10vh] md:pt-[10vh]">
      <h3 class="small-heading text-center py-12">
        QUALITY &amp; AFFORDABILITY SINCE 1984
      </h3>
      <p id="highlight-text" class="body-text-large max-w-6xl mx-auto px-8">
        We have over 90 stores in South Africa and a few in Mozambique. We have
        a mission to support the market by providing quality, affordability &
        convenience
      </p>
      <div class="text-center mt-8 mb-20">
        <a
          href="/about-us"
          class="small-heading scale-70 relative inline-block group transition-opacity duration-300 ease-out"
        >
          <span
            class="inline-block transition-transform duration-300 ease-out group-hover:-skew-x-12"
            >ABOUT OBC</span
          >
          <span
            class="absolute right-0 -bottom-1 w-full h-[2px] bg-current transition-all duration-300 ease-out group-hover:w-0"
          ></span>
        </a>
      </div>
      <!-- Department image card section -->
      <DepartmentCards
        cards={[
          {
            image: butcherySpecialsImg,
            alt: "National Butchery Specials",
            title: "National Butchery Specials",
            buttonLabel: "View Specials",
            buttonHref: "/pdfs/butchery-specials.pdf",
            openInNewTab: true,
          },
          {
            image: liquorSpecialsImg,
            alt: "National Liquor Specials",
            title: "National Liquor Specials",
            buttonLabel: "View Specials",
            buttonHref: "/pdfs/liquor-specials.pdf",
            openInNewTab: true,
          },
          {
            image: storeFinderImg,
            alt: "Find an OBC Near You",
            title: "Find an OBC Near You",
            buttonLabel: "Store Finder",
            buttonHref: "/store-finder",
            openInNewTab: false,
          },
        ]}
      />

      <!-- Department Icons Section -->
      <DepartmentIcons />

      <!-- Blockman's Den Section -->
      <BlockmansDenPreview />

      <!-- Facebook Feed Section -->
      <!-- <FacebookFeed /> -->
      <p
        id="highlight-text-bottom"
        class="body-text-large max-w-6xl mx-auto mt-[25vh] mb-[10vh] px-8"
      >
        Experience the difference with OBC - the home of quality, affordability,
        and Kasi convenience. We’re more than just a butchery. Our stores are
        stocked with everything from fresh produce to groceries, ensuring your
        budget goes further without compromising on that A-grade taste. Whether
        you’re fueling the hustle or feeding the whole family, we’ve got you
        covered under one roof with the freshest deals in town. <br /><br
        /><span class="font-black">#JoinTheBraaiNation</span>
      </p>

      <!-- Thola Zonke Banner -->
      <div class="pt-[10vh] md:pt[25vh] w-full z-40">
        <Carousel client:load images={tholaZonkeImage} />
      </div>
      <div class="w-full z-9999 overflow-hidden leading-none">
        <Image
          src={pattern}
          alt=""
          aria-hidden="true"
          class="w-full h-auto block"
          loading="eager"
        />
      </div>
    </div>

    <!-- Sticky Scatter Gallery -->
    <div class="relative z-30 w-full bg-brand-bg">
      <ScatterGallery
        client:load
        anchorImage={anchorImage}
        images={scatterImages}
      />
    </div>
  </div>
</BaseLayout>

