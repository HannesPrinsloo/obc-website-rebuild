            line.style.position = "relative";

            const mask = document.createElement("span");
            mask.className =
              "absolute top-0 left-0 w-full h-[115%] bg-brand-bg opacity-[0.85] z-10 origin-left scale-x-0 pointer-events-none";
            line.appendChild(mask);
            masks.push(mask);
          });

          gsap.to(masks, {
            scaleX: 1,
            ease: "none",
            duration: 1,
            stagger: 1,
            scrollTrigger: {
              trigger: highlightText,
              start: "top 50%",
