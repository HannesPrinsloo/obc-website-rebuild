---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactObfuscator from "../components/global/ContactObfuscator.astro";
---

<BaseLayout title="Contact Us">
  <div class="bg-brand-bg w-full min-h-[70vh] flex items-center pt-24 pb-24">
    <div
      class="max-w-6xl mx-auto px-6 md:px-12 w-full flex flex-col md:flex-row items-center md:items-stretch justify-between gap-12 lg:gap-20"
    >
      <!-- Left Column -->
      <div class="w-full md:w-[55%] flex flex-col justify-center">
        <div class="mb-8">
          <p
            class="text-brand-dark uppercase tracking-[0.2em] text-sm md:text-[15px] font-sans font-semibold mt-10 mb-3"
          >
            CONTACT US
          </p>
          <h1
            class="text-5xl md:text-6xl lg:text-[72px] font-sans font-bold text-brand-dark tracking-tight leading-none mb-0"
          >
            Get in touch
          </h1>
        </div>

        <div
          class="font-sans text-brand-dark space-y-6 text-[1.3rem] leading-6 max-w-md"
        >
          <p>We'd love to hear from you.</p>
          <p>
            To send us your question, complaint, suggestion - or to simply say
            hello, send us an email, drop us a line, or send us a message.
          </p>
          <p>
            View OBC Internal Complaints Handling Process
            <a
              href="/pdfs/obc-complaints-handling.pdf"
              target="_blank"
              rel="noopener noreferrer"
              class="font-bold hover:text-brand-primary transition-colors"
              >Here</a
            >
          </p>
        </div>
      </div>

      <!-- Right Column with Vertical Divider -->
      <div
        class="w-full md:w-[45%] md:pl-12 lg:pl-20 md:border-l-[1.5px] border-brand-dark flex flex-col justify-center space-y-10 mt-8 md:mt-0 py-4"
      >
        <!-- Address -->
        <div>
          <p
            class="font-sans font-bold text-brand-dark uppercase tracking-[0.1em] mb-3"
          >
            HEAD OFFICE:
          </p>
          <div class="font-sans text-gray-700 text-[1.3rem] leading-6">
            <p>OBC Group (PTY) LTD</p>
            <p>1158 Louwlardia Drive</p>
            <p>Centurion, 1632</p>
          </div>
        </div>

        <!-- Customer Care -->
        <div>
          <p
            class="font-sans font-bold text-brand-dark uppercase tracking-[0.1em] mb-3"
          >
            CUSTOMER CARE:
          </p>
          <div class="font-sans text-gray-700 text-[1.3rem] leading-6">
            <p>Monday to Friday: 08H00 - 17H00</p>
            <p><ContactObfuscator phone="0861 622 622" /></p>
          </div>
        </div>

        <!-- Email -->
        <div>
          <p
            class="font-sans font-bold text-brand-dark uppercase tracking-[0.1em] mb-3"
          >
            EMAIL:
          </p>
          <div class="font-sans text-gray-700 text-[1.3rem] leading-6">
            <ContactObfuscator email="complaints@obc.co.za" />
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
