---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Picture } from "astro:assets";
import tholaPhoneImg from "../assets/images/thola-zonke/thola-phone.webp";
import tholaCardImg from "../assets/images/thola-zonke/thola-card.webp";
import tholaBgImg from "../assets/images/thola-zonke/thola-bg.webp";
import tholaIcon1 from "../assets/images/thola-zonke/icon-1-thola.webp";
import tholaIcon2 from "../assets/images/thola-zonke/icon-2-thola.webp";
import tholaIcon3 from "../assets/images/thola-zonke/icon-3-thola.webp";
import tholaIcon4 from "../assets/images/thola-zonke/icon-4-thola.webp";
import tholaFistBumpImg from "../assets/images/thola-zonke/fist-bump-thola.webp";
---

<BaseLayout title="Thola Zonke">
    <div class="relative w-full bg-[#181818]">
        <section
            class="hero-wrapper relative w-full h-auto min-h-[100svh] lg:min-h-[80vh] lg:h-[clamp(calc(80vh),120vh,120vh)] md:h-[80vh] overflow-hidden flex flex-col lg:flex-row items-center pt-0 pb-8 md:pb-12 md:pt-10"
        >
            <div
                class="hero-bg-layer absolute right-0 bottom-0 top-[28%] lg:top-0 w-full md:w-[65%] z-0 flex justify-end pointer-events-none opacity-0 translate-x-12"
            >
                <Picture
                    src={tholaBgImg}
                    alt="Orange Diagonal Background"
                    class="h-full w-full object-cover object-left"
                    loading="eager"
                    fetchpriority="high"
                />
            </div>

            <div
                class="relative z-30 flex-1 w-full h-full flex flex-col justify-center px-6 md:px-12 lg:px-24 xl:pl-[12%] pointer-events-none"
            >
                <div
                    class="hero-text-layer flex flex-col items-center lg:items-start space-y-4 md:space-y-6 pointer-events-auto opacity-0"
                >
                    <h1
                        class="font-sans font-bold uppercase p-0 tracking-wide leading-[1.05] text-[clamp(3.5rem,7vw,8rem)] whitespace-nowrap text-center lg:text-left"
                    >
                        <span class="text-brand-primary">NEXT</span>
                        <span class="text-white">GEN</span><br />
                        <span class="text-white">OF</span>
                        <span class="text-brand-primary">REWARDS</span>
                    </h1>

                    <div
                        class="mt-4 lg:mt-6 text-center lg:text-left text-white w-full lg:max-w-xl hero-subtitle flex flex-col items-center lg:items-start"
                    >
                        <p
                            class="text-sm md:text-base -mt-6 md:-mt-12 lg:text-[clamp(1rem,1.5vw,1.35rem)] font-bold tracking-widest uppercase leading-snug max-w-[280px] md:max-w-none mx-auto lg:mx-0"
                        >
                            JOIN OUR THOLA ZONKE LOYALTY, STOKVEL<br
                                class="hidden md:block"
                            />
                            &amp; REWARDS PROGRAM TODAY.
                        </p>

                        <div class="mt-6 md:mt-8">
                            <p
                                class="text-xs md:text-xs font-bold tracking-[0.2em] uppercase mb-5 text-gray-300"
                            >
                                ALREADY A MEMBER? SIGN IN HERE
                            </p>

                            <div
                                class="flex flex-col lg:flex-row items-center lg:items-start justify-center lg:justify-start gap-4 px-4 lg:px-0 w-full"
                            >
                                <button
                                    class="btn-outline w-full max-w-[220px] lg:w-auto bg-brand-primary before:bg-[#181818] text-brand-light font-bold text-xs md:text-sm px-8 py-3 rounded-full border-brand-primary uppercase tracking-widest hover:opacity-90 transition-opacity"
                                >
                                    LOG IN
                                </button>
                                <button
                                    class="thola-install-btn w-full max-w-[220px] lg:w-auto bg-transparent border border-gray-400 text-white font-bold text-xs md:text-sm px-6 py-3 rounded-full uppercase tracking-widest"
                                >
                                    INSTALL APP
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div
                class="relative z-20 flex-1 w-full h-[60vh] lg:h-full flex justify-center items-center px-4 md:px-8 pointer-events-none mt-2 md:mt-12 lg:mt-0"
            >
                <div
                    class="relative w-[85%] max-w-[450px] md:max-w-[600px] lg:max-w-[700px] xl:max-w-[800px] h-full flex justify-center items-center group lg:scale-100 xl:scale-110 lg:origin-right"
                >
                    <div
                        class="hero-phone-layer absolute z-30 opacity-0 -translate-y-30 w-full flex justify-center"
                    >
                        <Picture
                            src={tholaPhoneImg}
                            alt="Thola Zonke App Phone"
                            loading="eager"
                            fetchpriority="high"
                            class="w-full h-auto max-h-[70vh] lg:max-h-[85vh] object-contain drop-shadow-2xl"
                        />
                    </div>
                    <div
                        class="hero-card-layer absolute z-40 opacity-0 translate-x-24 bottom-[-10vh] right-[5%] lg:bottom-[20%] lg:-right-[0%] w-[55%] lg:w-[70%]"
                    >
                        <Picture
                            src={tholaCardImg}
                            alt="Thola Zonke Card"
                            loading="eager"
                            fetchpriority="high"
                            class="w-full h-auto object-contain drop-shadow-2xl"
                        />
                    </div>
                </div>
            </div>
        </section>
        <section
            class="w-full flex flex-col items-center justify-center pt-8 md:pt-30 pb-24 md:pb-40 px-6 md:px-12 relative z-20"
        >
            <p
                id="highlight-text"
                class="body-text-large text-brand-light text-center max-w-5xl mt-6 md:mt-20 mb-16 md:mb-24"
            >
                Life’s circumstances can tempt you to spend which can make
                managing your money difficult. By joining Thola Zonke Rewards
                Club, you use your money in a way that your whole family will
                benefit.
            </p>

            <div
                class="thola-carousel-grid flex md:grid md:grid-cols-2 lg:grid-cols-4 overflow-x-auto md:overflow-x-visible snap-x snap-mandatory gap-4 md:gap-6 lg:gap-8 w-full max-w-7xl mx-auto pb-4 md:pb-0"
            >
                <div
                    class="thola-feature-card shrink-0 w-[85vw] md:w-auto snap-start cursor-default bg-black rounded-[2.5rem] p-8 flex flex-col items-center text-center justify-start shadow-xl"
                >
                    <Picture
                        src={tholaIcon1}
                        alt="ID Book"
                        class="w-full max-w-[170px] h-auto object-contain mb-8 lg:mb-12"
                        loading="lazy"
                    />
                    <p
                        class="text-[#EFEFEF] text-xs md:text-sm font-medium leading-relaxed max-w-[220px]"
                    >
                        Go to your nearest OBC Better Butchery. Bring along your
                        ID book or Passport to join.
                    </p>
                </div>

                <div
                    class="thola-feature-card shrink-0 w-[85vw] md:w-auto snap-start cursor-default bg-black rounded-[2.5rem] p-8 flex flex-col items-center text-center justify-start shadow-xl"
                >
                    <Picture
                        src={tholaIcon2}
                        alt="Camera or scanning"
                        class="w-full max-w-[168px] h-auto object-contain mb-8 lg:mb-12"
                        loading="lazy"
                    />
                    <p
                        class="text-[#EFEFEF] text-xs md:text-sm font-medium leading-relaxed max-w-[220px]"
                    >
                        An OBC staff member will scan your ID book, capture your
                        details and request your cellphone number.
                    </p>
                </div>

                <div
                    class="thola-feature-card shrink-0 w-[85vw] md:w-auto snap-start cursor-default bg-black rounded-[2.5rem] p-8 flex flex-col items-center text-center justify-start shadow-xl"
                >
                    <Picture
                        src={tholaIcon3}
                        alt="PIN entry"
                        class="w-full max-w-[171px] h-auto object-contain mb-8 lg:mb-12"
                        loading="lazy"
                    />
                    <p
                        class="text-[#EFEFEF] text-xs md:text-sm font-medium leading-relaxed max-w-[220px]"
                    >
                        You will be asked to choose a PIN that you must
                        remember.
                    </p>
                    <p
                        class="text-[9px] font-bold uppercase tracking-wider text-gray-400 mt-4"
                    >
                        NB: DO NOT SHARE THIS PIN WITH ANYBODY
                    </p>
                </div>

                <div
                    class="thola-feature-card shrink-0 w-[85vw] md:w-auto snap-start cursor-default bg-black rounded-[2.5rem] p-8 flex flex-col items-center text-center justify-start shadow-xl"
                >
                    <Picture
                        src={tholaIcon4}
                        alt="OTP on phone"
                        class="w-full max-w-[147px] h-auto object-contain mb-8 lg:mb-12"
                        loading="lazy"
                    />
                    <p
                        class="text-[#EFEFEF] text-xs md:text-sm font-medium leading-relaxed max-w-[220px]"
                    >
                        Once you have entered the OTP sent to your cellphone you
                        are good to go. You can now start to save and earn Thola
                        Zonke Loyalty benefits.
                    </p>
                </div>
            </div>

            <div
                id="thola-carousel-dots"
                class="flex md:hidden items-center justify-center gap-3 mt-6 w-full"
            >
                <button
                    class="carousel-dot w-4 h-2 rounded-full bg-white transition-all duration-300 pointer-events-auto"
                    data-index="0"
                    aria-label="Go to slide 1"></button>
                <button
                    class="carousel-dot w-2 h-2 rounded-full bg-[#333333] transition-all duration-300 pointer-events-auto"
                    data-index="1"
                    aria-label="Go to slide 2"></button>
                <button
                    class="carousel-dot w-2 h-2 rounded-full bg-[#333333] transition-all duration-300 pointer-events-auto"
                    data-index="2"
                    aria-label="Go to slide 3"></button>
                <button
                    class="carousel-dot w-2 h-2 rounded-full bg-[#333333] transition-all duration-300 pointer-events-auto"
                    data-index="3"
                    aria-label="Go to slide 4"></button>
            </div>

            <p
                id="text-under-card"
                class="body-text-large text-[#EFEFEF] text-center max-w-4xl mx-auto mt-20 md:mt-28"
            >
                Thola Zonke Rewards Club is where you can save and have access
                to benefits, savings deals and rewards.
            </p>
        </section>
    </div>

    <section
        class="thola-expect-section w-full grid grid-cols-1 lg:grid-cols-2 bg-[#181818] relative"
    >
        <div
            class="thola-expect-text-container w-full z-10 aspect-square lg:aspect-auto [perspective:800px]"
        >
            <div
                class="thola-expect-text bg-white w-full h-full flex flex-col items-center justify-center text-center px-8 md:px-12 lg:py-32 xl:p-24 2xl:p-32"
            >
                <h2
                    class="font-sans text-[22px] md:text-3xl lg:text-4xl xl:text-[2.5rem] text-[#181818] font-normal tracking-wide leading-snug md:leading-snug lg:leading-tight max-w-[20rem] md:max-w-2xl mx-auto"
                >
                    <span class="thola-expect-line block overflow-hidden"
                        ><span class="block"
                            >EXPECT <span class="font-black tracking-widest"
                                >GREAT BENEFITS</span
                            ></span
                        ></span
                    >
                    <span class="thola-expect-line block overflow-hidden"
                        ><span class="block"
                            >WHEN JOINING <span
                                class="font-black tracking-widest"
                                >THE THOLA</span
                            ></span
                        ></span
                    >
                    <span class="thola-expect-line block overflow-hidden"
                        ><span class="font-black tracking-widest block"
                            >ZONKE REWARDS CLUB</span
                        ></span
                    >
                </h2>
                <p
                    class="thola-expect-tag font-sans font-black text-[#181818] mt-6 lg:mt-10 tracking-widest text-sm md:text-[15px]"
                >
                    #expectmore
                </p>
            </div>
        </div>

        <div
            class="thola-expect-img-container relative w-full aspect-square lg:aspect-auto lg:h-full overflow-hidden [perspective:800px]"
        >
            <div
                class="thola-expect-img-wrap relative w-full h-full overflow-hidden flex items-center justify-center bg-[#ea9e48]"
            >
                <Picture
                    src={tholaFistBumpImg}
                    alt="Expect great benefits when joining the Thola Zonke Rewards Club"
                    class="thola-expect-img absolute lg:relative inset-0 lg:inset-auto w-full h-full lg:h-auto object-cover object-center lg:object-left"
                    loading="lazy"
                />
            </div>
        </div>
    </section>

    <section
        class="thola-promo-section relative w-full bg-[#181818] overflow-hidden h-[100svh] flex flex-col pt-[15svh]"
    >
        <div
            class="thola-cards-wrapper relative w-full flex-1 flex flex-col justify-center"
        >
            <div
                class="thola-cards-track flex gap-4 md:gap-6 lg:gap-8 pl-[30vw] pr-6 md:pr-12 w-[max-content]"
            >
                <div
                    class="thola-promo-card w-[85vw] md:w-[55vw] lg:w-[40vw] xl:w-[36vw] 2xl:w-[32vw] min-h-[420px] md:min-h-[500px] bg-brand-primary rounded-[2rem] p-8 md:p-12 flex flex-col justify-between shrink-0 shadow-xl pointer-events-none"
                >
                    <h3
                        class="text-white text-xl md:text-[1.25rem] font-bold uppercase tracking-widest font-sans leading-snug"
                    >
                        SAVINGS THAT SUITS YOU
                    </h3>
                    <p
                        class="text-white text-lg md:text-lg lg:text-[clamp(1.15rem,2vw,1.6rem)] font-medium uppercase leading-relaxed font-sans mt-4"
                    >
                        SAVE ACCORDING TO YOUR POCKET! TOP UP WITH YOUR REWARDS
                        CARD WITH ANY AMOUNT YOU CHOOSE AND CAN AFFORD
                    </p>
                </div>

                <div
                    class="thola-promo-card w-[85vw] md:w-[55vw] lg:w-[40vw] xl:w-[36vw] 2xl:w-[32vw] min-h-[420px] md:min-h-[500px] bg-brand-primary rounded-[2rem] p-8 md:p-12 flex flex-col justify-between shrink-0 shadow-xl pointer-events-none"
                >
                    <h3
                        class="text-white text-xl md:text-[1.25rem] font-bold uppercase tracking-widest font-sans leading-snug"
                    >
                        SHOP ANYWHERE
                    </h3>
                    <p
                        class="text-white text-lg md:text-lg lg:text-[clamp(1.15rem,2vw,1.6rem)] font-medium uppercase leading-relaxed font-sans mt-4"
                    >
                        YOU CAN TOP UP YOUR THOLA ZONKE REWARDS CARD AND SPEND
                        AT ANY OBC ACROSS THE COUNTRY
                    </p>
                </div>

                <div
                    class="thola-promo-card w-[85vw] md:w-[55vw] lg:w-[40vw] xl:w-[36vw] 2xl:w-[32vw] min-h-[420px] md:min-h-[500px] bg-brand-primary rounded-[2rem] p-8 md:p-12 flex flex-col justify-between shrink-0 shadow-xl pointer-events-none"
                >
                    <h3
                        class="text-white text-xl md:text-[1.25rem] font-bold uppercase tracking-widest font-sans leading-snug"
                    >
                        SEND A GIFT FROM ANYWHERE
                    </h3>
                    <p
                        class="text-white text-lg md:text-lg lg:text-[clamp(1.15rem,2vw,1.6rem)] font-medium uppercase leading-relaxed font-sans mt-4"
                    >
                        TOP UP YOUR FAMILY OR FRIENDS'S REWARDS CARD FROM
                        ANYWHERE IN THE COUNTRY - MAHALA!
                    </p>
                </div>

                <div
                    class="thola-promo-card w-[85vw] md:w-[55vw] lg:w-[40vw] xl:w-[36vw] 2xl:w-[32vw] min-h-[420px] md:min-h-[500px] bg-brand-primary rounded-[2rem] p-8 md:p-12 flex flex-col justify-between shrink-0 shadow-xl pointer-events-none"
                >
                    <h3
                        class="text-white text-xl md:text-[1.25rem] font-bold uppercase tracking-widest font-sans leading-snug"
                    >
                        BE THE FIRST TO KNOW
                    </h3>
                    <p
                        class="text-white text-lg md:text-lg lg:text-[clamp(1.15rem,2vw,1.6rem)] font-medium uppercase leading-relaxed font-sans mt-4"
                    >
                        BE THE FIRST TO KNOW ABOUT SPECIALS AND COMPETITIONS
                        BEFORE THEY ARE ANNOUNCED
                    </p>
                </div>

                <div
                    class="thola-promo-card w-[85vw] md:w-[55vw] lg:w-[40vw] xl:w-[36vw] 2xl:w-[32vw] min-h-[420px] md:min-h-[500px] bg-brand-primary rounded-[2rem] p-8 md:p-12 flex flex-col justify-between shrink-0 shadow-xl pointer-events-none"
                >
                    <h3
                        class="text-white text-xl md:text-[1.25rem] font-bold uppercase tracking-widest font-sans leading-snug"
                    >
                        DEALS JUST FOR YOU
                    </h3>
                    <p
                        class="text-white text-lg md:text-lg lg:text-[clamp(1.15rem,2vw,1.6rem)] font-medium uppercase leading-relaxed font-sans mt-4"
                    >
                        PARTAKE IN EXCLUSIVE DEALS, SAVINGS AND COMPETITIONS
                        ONLY AVAILABLE TO REWARDS MEMBERS
                    </p>
                </div>
            </div>
        </div>

        <div
            class="thola-stationary-text w-full flex flex-col items-center justify-center pb-[15svh] md:pb-[10svh] px-4 pointer-events-auto"
        >
            <p
                class="body-text-large text-brand-light text-center mt-10 max-w-4xl mx-auto mb-8"
            >
                Log in or install the app to track and view your savings
            </p>
            <div
                class="flex flex-col lg:flex-row items-center justify-center gap-4 w-full"
            >
                <button
                    class="btn-outline w-full max-w-[220px] lg:w-auto bg-brand-primary before:bg-[#181818] text-brand-light font-bold text-xs md:text-sm px-8 py-3 rounded-full border-brand-primary uppercase tracking-widest hover:opacity-90 transition-opacity"
                >
                    LOG IN
                </button>
                <button
                    class="thola-install-btn w-full max-w-[220px] lg:w-auto bg-transparent border mb-12 md:mb-0 border-gray-400 text-white font-bold text-xs md:text-sm px-6 py-3 rounded-full uppercase tracking-widest"
                >
                    INSTALL APP
                </button>
            </div>
        </div>
    </section>

    <section
        class="thola-faq-section w-full mt-12 md:mt-0 bg-brand-bg py-20 md:py-28 px-6 md:px-12"
    >
        <div class="max-w-3xl mx-auto">
            <p
                class="text-center font-sans font-bold text-sm tracking-[0.25em] uppercase text-[#181818] mb-4"
            >
                FREQUENTLY ASKED QUESTIONS
            </p>
            <h2
                class="font-sans font-normal text-center text-[#181818] text-2xl md:text-4xl mb-12 md:mb-16 leading-snug"
            >
                Know more about our Thola Zonke Rewards Card
            </h2>

            <div class="thola-faq-list flex flex-col">
                <!-- FAQ 1 -->
                <details
                    class="thola-faq-item group border-b border-[#181818] py-5 cursor-pointer"
                >
                    <summary
                        class="flex items-center justify-between list-none font-sans font-bold text-[#181818] text-base md:text-lg tracking-wide select-none"
                    >
                        When can I start saving?
                    </summary>
                    <p
                        class="font-sans text-[#444444] text-sm md:text-base leading-relaxed mt-4 max-w-2xl"
                    >
                        You can start saving at any time. The quicker you become
                        a member, the quicker you will start saving towards your
                        goal and benefit from all the promotions and specials
                        offered to Loyalty members.
                    </p>
                </details>

                <!-- FAQ 2 -->
                <details
                    class="thola-faq-item group border-b border-[#181818] py-5 cursor-pointer"
                >
                    <summary
                        class="flex items-center justify-between list-none font-sans font-bold text-[#181818] text-base md:text-lg tracking-wide select-none"
                    >
                        What if I lose my card?
                    </summary>
                    <p
                        class="font-sans text-[#444444] text-sm md:text-base leading-relaxed mt-4 max-w-2xl"
                    >
                        Come to your nearest store as soon as possible to get a
                        replacement card. Remember to bring you ID Book or
                        Passport with you. OBC will use your ID Book and your
                        existing PIN number to issue you with a new card. Please
                        note: Even if your card is stolen, no one will be able
                        to access your funds without your PIN number. Please
                        don’t give anyone your PIN number!
                    </p>
                </details>

                <!-- FAQ 3 -->
                <details
                    class="thola-faq-item group border-b border-[#181818] py-5 cursor-pointer"
                >
                    <summary
                        class="flex items-center justify-between list-none font-sans font-bold text-[#181818] text-base md:text-lg tracking-wide select-none"
                    >
                        What if I forget my PIN Number?
                    </summary>
                    <p
                        class="font-sans text-[#444444] text-sm md:text-base leading-relaxed mt-4 max-w-2xl"
                    >
                        Come to your nearest store as soon as possible to get a
                        new PIN. Remember to bring you ID Book or Passport with
                        you. OBC will use your ID Book and your existing card to
                        issue you with a new PIN. Remember: You will not be able
                        to use your card or access your funds without the
                        correct PIN.
                    </p>
                </details>

                <!-- FAQ 4 -->
                <details
                    class="thola-faq-item group border-b border-[#181818] py-5 cursor-pointer"
                >
                    <summary
                        class="flex items-center justify-between list-none font-sans font-bold text-[#181818] text-base md:text-lg tracking-wide select-none"
                    >
                        Can I have more than one card linked to my Loyalty
                        Wallet?
                    </summary>
                    <p
                        class="font-sans text-[#444444] text-sm md:text-base leading-relaxed mt-4 max-w-2xl"
                    >
                        No, for security reasons there will only be one card
                        linked per Loyalty Wallet.
                    </p>
                </details>

                <!-- FAQ 5 -->
                <details
                    class="thola-faq-item group border-b border-[#181818] py-5 cursor-pointer"
                >
                    <summary
                        class="flex items-center justify-between list-none font-sans font-bold text-[#181818] text-base md:text-lg tracking-wide select-none"
                    >
                        Can I use my Rewards card at any OBC Store?
                    </summary>
                    <p
                        class="font-sans text-[#444444] text-sm md:text-base leading-relaxed mt-4 max-w-2xl"
                    >
                        Yes. You can use your Rewards card at any participating
                        OBC store to top up to save or buy goods.
                    </p>
                </details>

                <!-- FAQ 6 -->
                <details
                    class="thola-faq-item group border-b border-[#181818] py-5 cursor-pointer"
                >
                    <summary
                        class="flex items-center justify-between list-none font-sans font-bold text-[#181818] text-base md:text-lg tracking-wide select-none"
                    >
                        Can I withdraw cash from my Rewards card?
                    </summary>
                    <p
                        class="font-sans text-[#444444] text-sm md:text-base leading-relaxed mt-4 max-w-2xl"
                    >
                        No, you cannot withdraw cash from your Rewards card.
                        Your Rewards card can only be used to save and purchase
                        goods from OBC stores.
                    </p>
                </details>

                <!-- FAQ 7 -->
                <details
                    class="thola-faq-item group border-b border-[#181818] py-5 cursor-pointer"
                >
                    <summary
                        class="flex items-center justify-between list-none font-sans font-bold text-[#181818] text-base md:text-lg tracking-wide select-none"
                    >
                        What happens if I die? Can my family withdraw or use my
                        funds?
                    </summary>
                    <p
                        class="font-sans text-brand-dark text-sm md:text-base leading-relaxed mt-4 max-w-2xl"
                    >
                        If you die, your family will need to bring a copy of
                        your ID Book and death certificate to a store. This will
                        be used by administration for assessment. Once the
                        assessment is complete, your family may then be given
                        access to your vouchers.
                    </p>
                </details>
            </div>
        </div>
    </section>

    <script>
        import { gsap } from "gsap";
        import { ScrollTrigger } from "gsap/ScrollTrigger";
        import { SplitText } from "gsap/SplitText";

        gsap.registerPlugin(ScrollTrigger, SplitText);

        let heroCtx: ReturnType<typeof gsap.context> | null;

        function initHeroAnimations() {
            if (heroCtx) {
                heroCtx.revert();
                heroCtx = null;
            }

            if (!document.querySelector(".hero-wrapper")) return;

            heroCtx = gsap.context(() => {
                requestAnimationFrame(() => {
                    // SplitText masked line reveal
                    SplitText.create(".hero-text-layer h1", {
                        type: "lines",
                        mask: "lines",
                        autoSplit: true,
                        onSplit: (self) => {
                            gsap.set(".hero-text-layer", { opacity: 1, y: 0 });
                            return gsap.from(self.lines, {
                                yPercent: 120,
                                duration: 1.2,
                                ease: "expo.out",
                                stagger: 0.05,
                                delay: 0.1,
                            });
                        },
                    });

                    gsap.from(".hero-subtitle", {
                        opacity: 0,
                        y: 20,
                        duration: 1,
                        ease: "power3.out",
                        delay: 0.6,
                    });

                    gsap.from(".thola-feature-card", {
                        opacity: 0,
                        y: 60,
                        duration: 1,
                        stagger: 0.3,
                        ease: "back.out(1.2)",
                        scrollTrigger: {
                            trigger: ".thola-feature-card",
                            start: "top 85%",
                        },
                    });

                    const featureCards = gsap.utils.toArray(
                        ".thola-feature-card",
                    ) as HTMLElement[];
                    featureCards.forEach((card) => {
                        card.addEventListener("mouseenter", () => {
                            gsap.to(card, {
                                y: -12,
                                duration: 0.3,
                                ease: "power2.out",
                            });
                        });
                        card.addEventListener("mouseleave", () => {
                            gsap.to(card, {
                                y: 0,
                                duration: 0.3,
                                ease: "power2.out",
                            });
                        });
                    });

                    const tl = gsap.timeline({
                        defaults: { ease: "power3.out" },
                    });

                    tl.to(
                        ".hero-bg-layer",
                        { opacity: 1, x: 0, duration: 1.5 },
                        0,
                    )
                        .to(
                            ".hero-phone-layer",
                            { opacity: 1, y: 0, duration: 1.2 },
                            "-=1.0",
                        )
                        .to(
                            ".hero-card-layer",
                            { opacity: 1, x: 0, y: 0, duration: 1.2 },
                            "-=0.9",
                        );

                    gsap.to(".hero-phone-layer", {
                        yPercent: -10,
                        ease: "none",
                        scrollTrigger: {
                            trigger: ".hero-wrapper",
                            start: "top top",
                            end: "bottom top",
                            scrub: true,
                        },
                    });

                    gsap.to(".hero-card-layer", {
                        yPercent: -25,
                        rotation: -3,
                        ease: "none",
                        scrollTrigger: {
                            trigger: ".hero-wrapper",
                            start: "top top",
                            end: "bottom top",
                            scrub: true,
                        },
                    });

                    const highlightText =
                        document.querySelector("#highlight-text");
                    if (highlightText) {
                        const splitHighlight = new SplitText(highlightText, {
                            type: "lines",
                        });

                        const masks: HTMLElement[] = [];
                        splitHighlight.lines.forEach((line) => {
                            line.style.position = "relative";

                            const mask = document.createElement("span");
                            mask.className =
                                "absolute top-0 left-0 w-full h-[115%] bg-[#181818] opacity-[0.85] z-10 origin-left scale-x-0 pointer-events-none";
                            line.appendChild(mask);
                            masks.push(mask);
                        });

                        gsap.to(masks, {
                            scaleX: 1,
                            ease: "none",
                            duration: 1,
                            stagger: 1,
                            scrollTrigger: {
                                trigger: highlightText,
                                start: "top 50%",
                                end: "bottom 15%",
                                scrub: true,
                            },
                        });
                    }

                    const underCardHighlight =
                        document.querySelector("#text-under-card");
                    if (underCardHighlight) {
                        const splitFooter = new SplitText(underCardHighlight, {
                            type: "lines",
                        });

                        const footerMasks: HTMLElement[] = [];
                        splitFooter.lines.forEach((line) => {
                            line.style.position = "relative";
                            const mask = document.createElement("span");
                            mask.className =
                                "absolute top-0 left-0 w-full h-[115%] bg-[#181818] opacity-[0.85] z-10 origin-left scale-x-0 pointer-events-none";
                            line.appendChild(mask);
                            footerMasks.push(mask);
                        });

                        gsap.to(footerMasks, {
                            scaleX: 1,
                            ease: "none",
                            duration: 1,
                            stagger: 1,
                            scrollTrigger: {
                                trigger: underCardHighlight,
                                start: "top 75%",
                                end: "bottom 35%",
                                scrub: true,
                            },
                        });
                    }

                    const expectSection = document.querySelector(
                        ".thola-expect-section",
                    );
                    if (expectSection) {
                        const expectText =
                            expectSection.querySelector(".thola-expect-text");
                        const expectImgWrap = expectSection.querySelector(
                            ".thola-expect-img-wrap",
                        );

                        const expectTl = gsap.timeline({
                            scrollTrigger: {
                                trigger: expectSection,
                                start: "top 85%",
                                end: "top 0%",
                                scrub: 1,
                            },
                        });

                        if (expectText) {
                            expectTl.from(
                                expectText,
                                {
                                    y: -100,
                                    rotationX: 7,
                                    transformOrigin: "bottom center",
                                    ease: "power1.out",
                                },
                                0,
                            );
                        }

                        if (expectImgWrap) {
                            expectTl.from(
                                expectImgWrap,
                                {
                                    y: 100,
                                    rotationX: -7,
                                    transformOrigin: "top center",
                                    ease: "power1.out",
                                },
                                0,
                            );
                        }
                    }
                });
            });
        }
        function initCarouselTracking() {
            const grid = document.querySelector(
                ".thola-carousel-grid",
            ) as HTMLElement;
            const cards = document.querySelectorAll(
                ".thola-carousel-grid .thola-feature-card",
            );
            const dots = document.querySelectorAll(
                "#thola-carousel-dots .carousel-dot",
            );

            if (!grid || cards.length === 0 || dots.length === 0) return;

            dots.forEach((dot, index) => {
                dot.addEventListener("click", () => {
                    const card = cards[index] as HTMLElement;
                    if (card) {
                        grid.scrollTo({
                            left: card.offsetLeft - grid.offsetLeft,
                            behavior: "smooth",
                        });
                    }
                });
            });

            const observer = new IntersectionObserver(
                (entries) => {
                    entries.forEach((entry) => {
                        if (entry.isIntersecting) {
                            const index = Array.from(cards).indexOf(
                                entry.target,
                            );
                            if (index !== -1 && dots[index]) {
                                dots.forEach((d) => {
                                    d.classList.remove("bg-white", "w-4");
                                    d.classList.add("bg-[#333333]", "w-2");
                                });
                                dots[index].classList.remove(
                                    "bg-[#333333]",
                                    "w-2",
                                );
                                dots[index].classList.add("bg-white", "w-4");
                            }
                        }
                    });
                },
                {
                    root: grid,
                    threshold: 0.6,
                },
            );

            cards.forEach((card) => observer.observe(card));

            document.addEventListener(
                "astro:before-swap",
                () => {
                    observer.disconnect();
                },
                { once: true },
            );
        }

        let horizontalOrangeCtx: ReturnType<typeof gsap.context> | null;

        function initPromoHorizontalScroll() {
            if (horizontalOrangeCtx) {
                horizontalOrangeCtx.revert();
                horizontalOrangeCtx = null;
            }

            const section = document.querySelector(".thola-promo-section");
            const track = document.querySelector(".thola-cards-track");

            if (!section || !track) return;

            horizontalOrangeCtx = gsap.context(() => {
                const getScrollAmount = () =>
                    -(track.scrollWidth - window.innerWidth);
                if (track.scrollWidth > window.innerWidth) {
                    gsap.to(track, {
                        x: getScrollAmount,
                        ease: "none",
                        scrollTrigger: {
                            trigger: section,
                            start: "top top",
                            end: () => `+=${track.scrollWidth}`,
                            pin: true,
                            scrub: 1,
                            invalidateOnRefresh: true,
                        },
                    });
                }
            }, section);
        }

        document.addEventListener("astro:page-load", () => {
            initHeroAnimations();
            initCarouselTracking();
            initPromoHorizontalScroll();

            const images = document.querySelectorAll("img");
            images.forEach((img) => {
                if (!img.complete) {
                    img.addEventListener("load", () => {
                        ScrollTrigger.refresh();
                    });
                }
            });

            requestAnimationFrame(() => ScrollTrigger.refresh());
            setTimeout(() => ScrollTrigger.refresh(), 500);

            initFaqAnimations();
        });

        function initFaqAnimations() {
            const items =
                document.querySelectorAll<HTMLDetailsElement>(
                    ".thola-faq-item",
                );

            items.forEach((details) => {
                const summary = details.querySelector("summary");
                if (!summary) return;

                const contentNodes = Array.from(details.children).filter(
                    (node) => node !== summary,
                ) as HTMLElement[];

                const wrapper = document.createElement("div");
                wrapper.style.overflow = "hidden";
                wrapper.style.height = "0";
                contentNodes.forEach((node) => wrapper.appendChild(node));
                details.appendChild(wrapper);

                summary.addEventListener("click", (e) => {
                    e.preventDefault();

                    if (details.open) {
                        gsap.to(wrapper, {
                            height: 0,
                            duration: 0.4,
                            ease: "power3.inOut",
                            onComplete: () => details.removeAttribute("open"),
                        });
                    } else {
                        details.setAttribute("open", "");
                        gsap.fromTo(
                            wrapper,
                            { height: 0 },
                            {
                                height: "auto",
                                duration: 0.4,
                                ease: "power3.inOut",
                            },
                        );
                    }
                });
            });
        }
    </script>
</BaseLayout>

<style>
    .thola-carousel-grid {
        scrollbar-width: none;
        -ms-overflow-style: none;
    }
    .thola-carousel-grid::-webkit-scrollbar {
        display: none;
    }

    .thola-install-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
        transition:
            border-color 0.35s ease,
            letter-spacing 0.35s ease,
            color 0.35s ease;
        z-index: 1;
    }

    .thola-install-btn::before {
        content: "";
        position: absolute;
        inset: 0;
        background-color: var(--color-brand-primary);
        clip-path: inset(0 100% 0 0);
        transition: clip-path 0.45s cubic-bezier(0.4, 0, 0.2, 1);
        z-index: -1;
    }

    .thola-install-btn:hover {
        border-color: var(--color-brand-dark) !important;
        color: var(--color-brand-dark) !important;
        letter-spacing: 0.14em;
        text-wrap: nowrap;
    }

    .thola-install-btn:hover::before {
        clip-path: inset(0 0% 0 0);
    }
</style>
