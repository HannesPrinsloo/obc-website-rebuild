---
import iconServes from "../../assets/images/recipes/icon-serves.svg";
import iconPrepTime from "../../assets/images/recipes/icon-prep-time.svg";
import iconCookTime from "../../assets/images/recipes/icon-cook-time.svg";
import iconDifficulty from "../../assets/images/recipes/icon-difficulty.svg";

interface RecipeData {
    id: string;
    slug: string;
    title: string;
    byLine: string;
    serves: string;
    prepTime: string;
    cookTime: string;
    difficulty: string;
    ingredients: string[];
    method: string[];
    imageSrc: string;
}

interface Props {
    dinnerRecipes: RecipeData[];
    sweetRecipes: RecipeData[];
}

const { dinnerRecipes, sweetRecipes } = Astro.props;

const icons = {
    serves: iconServes.src,
    prepTime: iconPrepTime.src,
    cookTime: iconCookTime.src,
    difficulty: iconDifficulty.src,
};

const storeData = { dinner: dinnerRecipes, sweet: sweetRecipes, icons };
---

<script
    id="recipe-data-store"
    type="application/json"
    set:html={JSON.stringify(storeData)}
/>

<div id="recipes-root" class="max-w-7xl mx-auto py-16 pt-24 md:pt-40 px-4">
    <section id="dinner-section">
        <div class="text-left mb-16 md:mb-30">
            <h2 class="text-5xl font-sans font-bold text-brand-dark mb-4">
                Dinner sorted.
            </h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {
                dinnerRecipes.map((recipe) => (
                    <a
                        href={`?recipe=${recipe.slug}`}
                        id={recipe.id}
                        data-id={recipe.id}
                        class="recipe-card group bg-white rounded-lg shadow-md overflow-hidden hover:shadow-xl transition-all duration-300 border border-gray-100 block cursor-pointer"
                    >
                        <div class="relative h-52 bg-gray-200 overflow-hidden">
                            <img
                                src={recipe.imageSrc}
                                alt={recipe.title}
                                class="absolute inset-0 w-full h-full object-cover scale-110 transition-transform duration-500 group-hover:scale-100"
                                loading="lazy"
                            />
                        </div>
                        <div class="p-6">
                            <h3 class="text-lg font-bold text-brand-dark mb-1 group-hover:text-brand-primary transition-colors">
                                {recipe.title}
                            </h3>
                            <p class="text-sm text-gray-400 mb-4">
                                {recipe.byLine}
                            </p>
                            <div class="flex justify-between text-sm text-gray-500 font-medium">
                                <span>⏱ {recipe.cookTime}</span>
                                <span class="inline-flex items-center gap-1">
                                    <img
                                        src={iconDifficulty.src}
                                        alt=""
                                        class="w-4 h-4 object-contain opacity-70"
                                    />
                                    {recipe.difficulty}
                                </span>
                            </div>
                        </div>
                    </a>
                ))
            }
        </div>
    </section>

    <section id="sweet-section">
        <div class="text-left mt-20 md:mt-30 mb-16 md:mb-30">
            <h2 class="text-5xl font-sans font-bold text-brand-dark mb-4">
                Sweet things
            </h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {
                sweetRecipes.map((recipe) => (
                    <a
                        href={`?recipe=${recipe.slug}`}
                        id={recipe.id}
                        data-id={recipe.id}
                        class="recipe-card group bg-white rounded-lg shadow-md overflow-hidden hover:shadow-xl transition-all duration-300 border border-gray-100 block cursor-pointer"
                    >
                        <div class="relative h-52 bg-gray-200 overflow-hidden">
                            <img
                                src={recipe.imageSrc}
                                alt={recipe.title}
                                class="absolute inset-0 w-full h-full object-cover scale-110 transition-transform duration-500 group-hover:scale-100"
                                loading="lazy"
                            />
                        </div>
                        <div class="p-6">
                            <h3 class="text-lg font-bold text-brand-dark mb-1 group-hover:text-brand-primary transition-colors">
                                {recipe.title}
                            </h3>
                            <p class="text-sm text-gray-400 mb-4">
                                {recipe.byLine}
                            </p>
                            <div class="flex justify-between text-sm text-gray-500 font-medium">
                                <span>⏱ {recipe.cookTime}</span>
                                <span class="inline-flex items-center gap-1">
                                    <img
                                        src={iconDifficulty.src}
                                        alt=""
                                        class="w-4 h-4 object-contain opacity-70"
                                    />
                                    {recipe.difficulty}
                                </span>
                            </div>
                        </div>
                    </a>
                ))
            }
        </div>
    </section>

    <section
        id="recipe-detail"
        class="font-sans"
        style="display: none; opacity: 0;"
    >
    </section>
</div>

<button
    id="recipe-escape-hatch"
    class="fixed top-24 right-6 z-[200] w-[46px] h-[46px] bg-white/70 backdrop-blur-md flex items-center justify-center rounded-full border border-gray-300 hover:bg-brand-primary hover:border-brand-primary hover:text-white transition-all duration-300 cursor-pointer group hover:scale-110 shadow-md hidden"
    aria-label="Back to all recipes"
>
    <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="2"
        stroke="currentColor"
        class="w-5 h-5 group-hover:rotate-90 transition-transform duration-500 ease-out"
    >
        <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M6 18 18 6M6 6l12 12"></path>
    </svg>
</button>

<style is:global>
    .recipe-card {
        will-change: transform, opacity;
    }

    #recipes-root.detail-active {
        /* padding-top: 0; */
    }

    #recipe-detail.detail-active {
        /* margin-top: 5.5rem; */
    }

    #recipe-detail {
        max-width: 860px;
        margin: 2rem auto 5rem;
        padding: 0;
    }

</style>

<script src="../../scripts/recipes.ts"></script>
