---
import { getImage, Image } from "astro:assets";
import blockmansData from "../../data/blockmans-den.json";

import beefImg from "../../assets/images/blockmans-den/beef/beef-illustration.svg";
import poultryImg from "../../assets/images/blockmans-den/poultry/poultry-illustration.svg";
import porkImg from "../../assets/images/blockmans-den/pork/pork-illustration.svg";
import muttonImg from "../../assets/images/blockmans-den/mutton/mutton-illustration.svg";

interface Props {
    animalId: "Beef" | "Poultry" | "Pork" | "Mutton";
}

const { animalId = "Beef" } = Astro.props;

const animals = [
    { id: 1, name: "Beef", Image: beefImg },
    { id: 2, name: "Poultry", Image: poultryImg },
    { id: 3, name: "Pork", Image: porkImg },
    { id: 4, name: "Mutton", Image: muttonImg },
];

const currentAnimal = animals.find((a) => a.name === animalId) || animals[0];

const imageModules = import.meta.glob<{ default: ImageMetadata }>(
    "../../assets/images/blockmans-den/**/*.{webp,svg,jpg,png}",
    { eager: true },
);

async function getOpt(srcPath: string) {
    if (!srcPath) return "";
    const lookupKey = "../../" + srcPath.replace("../", "");

    const mod = imageModules[lookupKey];
    if (mod && mod.default) {
        if (srcPath.endsWith(".svg")) return mod.default.src;
        const opt = await getImage({ src: mod.default, format: "webp" });
        return opt.src;
    }
    console.error("Vite Glob could not find this image locally:", lookupKey);
    return srcPath;
}

const cutsData = await Promise.all(
    // @ts-ignore - dynamic indexing
    blockmansData[animalId].map(async (cut) => ({
        Title: cut.Title,
        Description: cut.Description,
        ImageObj: await getOpt(cut.Image),
        highlightImageObj: await getOpt(cut.highlightImage),
        cookingGuideObj: await getOpt(cut.cookingGuide),
    })),
);
---

<div
    class="h-screen w-full relative bg-brand-light font-sans z-20 overflow-hidden"
>
    <img
        src={currentAnimal.Image.src}
        alt={currentAnimal.name}
        loading="lazy"
        decoding="async"
        class={`absolute left-1/2 -translate-x-1/2 bottom-[22%] h-[55vh] md:h-[60vh] w-auto max-w-[120vw] md:max-w-none object-contain pointer-events-none ${currentAnimal.name === "Pork" ? "scale-[0.6] md:scale-100 origin-bottom" : ""}`}
    />

    <!-- Text Layer -->
    <div
        class="absolute bottom-[10%] md:bottom-[12%] left-0 w-full flex flex-col items-center text-center"
    >
        <h2
            class="text-4xl md:text-5xl font-black uppercase tracking-wider mb-2 relative inline-block text-[#222]"
        >
            {currentAnimal.name} CUTS
            <div
                class="absolute -bottom-2 left-0 right-0 h-[2px] bg-brand-primary"
            >
            </div>
        </h2>
        <p
            class="mt-4 text-[0.65rem] md:text-sm font-bold uppercase tracking-widest text-[#222]"
        >
            Get to know your <span class="font-black">better</span> meat cuts
        </p>
    </div>

    <!-- Mobile Downward Scroll Indicator -->
    <div
        class="absolute bottom-[2%] md:bottom-[4%] left-1/2 -translate-x-1/2 z-10 pointer-events-auto flex flex-col items-center"
    >
        <div
            class="w-8 h-8 md:w-10 md:h-10 rounded-full border border-[#f58120] text-[#f58120] flex justify-center items-center animate-bounce"
        >
            <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
            >
                <line x1="12" y1="4" x2="12" y2="20"></line>
                <polyline points="18 14 12 20 6 14"></polyline>
            </svg>
        </div>
    </div>
</div>

<div
    class="explorer-container w-full h-screen overflow-hidden relative bg-[#efefef] font-sans"
>
    <!-- The panel that JS updates (now absolutely positioned as overlays) -->
    <h2
        id="panel-title"
        class="title absolute top-[12vh] lg:top-[15vh] left-1/2 -translate-x-1/2 w-[90vw] lg:w-auto text-center text-4xl lg:text-5xl tracking-[0.3em] font-black m-0 text-[#222] z-10 pointer-events-none"
    >
        {cutsData[0].Title.toUpperCase()}
    </h2>

    <!-- The Carousel Track (Now takes full screen to float behind text) -->
    <div
        class="carousel-viewport absolute lg:static top-[18vh] lg:top-0 h-[35vh] lg:h-screen w-full flex items-center z-5"
    >
        <div
            class="carousel-track flex h-full items-center pl-[15vw] pr-[15vw] lg:pl-[32.5vw] lg:pr-[32.5vw] gap-[5vw]"
            id="carousel-track"
        >
            {
                cutsData.map((item) => (
                    <div class="gallery-item w-[70vw] lg:w-[35vw] shrink-0 flex justify-center items-center will-change-transform">
                        <img
                            class="max-h-[30vh] lg:max-h-[45vh] max-w-full object-contain filter drop-shadow-[0_20px_30px_rgba(0,0,0,0.15)]"
                            src={item.ImageObj}
                            alt={item.Title}
                        />
                    </div>
                ))
            }
        </div>
    </div>

    <!-- The bottom grid for info -->
    <div
        class="info-grid absolute bottom-[2vh] lg:bottom-[5vh] left-0 w-full z-10 pointer-events-none px-[4vw]"
    >
        <div
            class="info-grid-inner flex flex-col lg:flex-row justify-between items-center lg:items-end w-full max-w-[1400px] gap-2 lg:gap-[30px] mx-auto pb-safe"
        >
            <div
                class="cow-diagram order-2 lg:order-1 flex-1 max-w-[140px] lg:max-w-[250px] mb-1 lg:mb-5"
            >
                <img
                    id="panel-cow-img"
                    class="w-full h-auto object-contain"
                    src={cutsData[0].highlightImageObj}
                    alt="Cow Diagram"
                />
            </div>
            <div
                class="description-container order-1 lg:order-2 flex-2 text-center text-sm lg:text-[1.15rem] font-medium leading-relaxed text-[#444] max-w-[450px] lg:max-w-[600px] mx-auto mb-4 lg:mb-10 px-4"
            >
                <p id="panel-desc">{cutsData[0].Description}</p>
            </div>

            <!-- Desktop Guide -->
            <div
                class="cooking-guide hidden lg:block order-3 flex-1 max-w-[320px] mb-5"
            >
                <img
                    id="panel-guide-img"
                    class="w-full h-auto object-contain"
                    src={cutsData[0].cookingGuideObj}
                    alt="Cooking Guide"
                />
            </div>

            <!-- Mobile Button -->
            <div
                class="mobile-guide-btn order-3 lg:hidden pointer-events-auto mb-3"
            >
                <button
                    id="guide-modal-btn"
                    class="border border-[#333] rounded-full px-6 py-2 text-[0.7rem] font-bold tracking-wide text-[#333] bg-transparent hover:bg-black hover:text-white transition-colors"
                    >COOKING GUIDE</button
                >
            </div>

            <!-- Mobile Downward Scroll Indicator -->
            <div
                class="scroll-arrow order-4 lg:hidden pointer-events-auto mt-2"
            >
                <div
                    class="w-12 h-12 rounded-full border border-[#f58120] text-[#f58120] flex justify-center items-center animate-bounce"
                >
                    <svg
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <line x1="12" y1="5" x2="12" y2="19"></line>
                        <polyline points="19 12 12 19 5 12"></polyline>
                    </svg>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Mobile Modal -->
<div
    id="cooking-guide-modal"
    class="fixed inset-0 z-100 hidden items-center justify-center opacity-0 transition-opacity duration-300 pointer-events-auto"
>
    <div
        id="modal-backdrop"
        class="absolute inset-0 bg-[#efefef]/90 backdrop-blur-md"
    >
    </div>
    <div class="relative bg-white shadow-2xl z-10 w-[90%] max-w-[400px]">
        <button
            id="close-modal-btn"
            class="absolute -top-4 -right-4 w-8 h-8 bg-white rounded-full flex items-center justify-center shadow-[0_4px_10px_rgba(0,0,0,0.1)] border border-gray-200"
        >
            <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="#666"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><line x1="18" y1="6" x2="6" y2="18"></line><line
                    x1="6"
                    y1="6"
                    x2="18"
                    y2="18"></line></svg
            >
        </button>
        <div class="p-2 border border-gray-100">
            <img
                id="modal-guide-img"
                src={cutsData[0].cookingGuideObj}
                alt="Cooking Guide"
                class="w-full h-auto"
            />
        </div>
    </div>
</div>

<div id="hs-end-section" class="h-[10vh] w-full bg-brand-light"></div>
<button
    onclick="window.location.href = '/blockmans-den'"
    class="fixed top-[12vh] lg:top-30 right-[4vw] lg:right-8 z-[200] w-[45px] h-[45px] lg:w-[50px] lg:h-[50px] bg-white/60 backdrop-blur-md flex items-center justify-center rounded-full border border-black hover:bg-brand-primary hover:text-[#181818] transition-all duration-300 cursor-pointer group hover:scale-110"
    aria-label="Return to all meats"
>
    <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="2"
        stroke="currentColor"
        class="w-5 h-5 group-hover:rotate-90 transition-transform duration-500 ease-out"
    >
        <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M6 18 18 6M6 6l12 12"></path>
    </svg>
</button>

<style>
    body {
        margin: 0;
        padding: 0;
        background-color: #efefef;
        font-family:
            ui-sans-serif, system-ui, sans-serif, "Apple Color Emoji",
            "Segoe UI Emoji", "Segoe UI Symbol", "Noto Color Emoji";
    }
</style>

<script
    id="carousel-data-store"
    type="application/json"
    set:html={JSON.stringify(cutsData)}
/>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    import { navigate } from "astro:transitions/client";
    import { prefetch } from "astro:prefetch";

    document.addEventListener("astro:page-load", () => {
        gsap.registerPlugin(ScrollTrigger);

        prefetch("/blockmans-den");

        const dataScript = document.getElementById("carousel-data-store");
        if (!dataScript) return;
        const cutsData = JSON.parse(dataScript.textContent);

        const track = document.getElementById("carousel-track");
        const titleEl = document.getElementById("panel-title");
        const descEl = document.getElementById("panel-desc");
        const cowEl = document.getElementById(
            "panel-cow-img",
        ) as HTMLImageElement;
        const guideEl = document.getElementById(
            "panel-guide-img",
        ) as HTMLImageElement;

        // Modal references
        const modal = document.getElementById("cooking-guide-modal");
        const modalImg = document.getElementById(
            "modal-guide-img",
        ) as HTMLImageElement;
        const openBtn = document.getElementById("guide-modal-btn");
        const closeBtn = document.getElementById("close-modal-btn");
        const backdrop = document.getElementById("modal-backdrop");

        const openModal = () => {
            modal?.classList.remove("hidden");
            modal?.classList.add("flex");
            requestAnimationFrame(() => modal?.classList.remove("opacity-0"));
        };
        const closeModal = () => {
            modal?.classList.add("opacity-0");
            setTimeout(() => {
                modal?.classList.add("hidden");
                modal?.classList.remove("flex");
            }, 300);
        };
        openBtn?.addEventListener("click", openModal);
        closeBtn?.addEventListener("click", closeModal);
        backdrop?.addEventListener("click", closeModal);

        const updatePanel = (index) => {
            const data = cutsData[index];
            if (!data) return;
            if (titleEl) titleEl.innerText = data.Title.toUpperCase();
            if (descEl) descEl.innerText = data.Description;
            if (cowEl) cowEl.src = data.highlightImageObj;
            if (guideEl) guideEl.src = data.cookingGuideObj;
            if (modalImg) modalImg.src = data.cookingGuideObj;
        };

        let ctx = gsap.context(() => {
            let track = document.getElementById("carousel-track");
            let items = gsap.utils.toArray(".gallery-item");
            const isMobile = window.innerWidth < 1024;
            const getMoveDistance = () =>
                isMobile ? window.innerWidth * 0.75 : window.innerWidth * 0.4;
            let activeIndex = 0;

            gsap.set(items, { scale: 0.5, filter: "blur(5px)" });
            gsap.set(items[0], { scale: 1, filter: "blur(0px)" });

            let tl = gsap.timeline({
                scrollTrigger: {
                    trigger: ".explorer-container",
                    pin: true,
                    scrub: 1,
                    end: () => "+=" + items.length * 1200,
                    invalidateOnRefresh: true,
                    onUpdate: () => {
                        let currentX = gsap.getProperty(track, "x") as number;
                        let calculatedIndex = Math.round(
                            Math.abs(currentX) / getMoveDistance(),
                        );

                        if (
                            calculatedIndex !== activeIndex &&
                            calculatedIndex < items.length
                        ) {
                            activeIndex = calculatedIndex;
                            updatePanel(activeIndex);
                        }
                    },
                },
            });

            items.forEach((item, i) => {
                if (i !== 0) {
                    tl.to(track, {
                        x: () => -(i * getMoveDistance()),
                        ease: "power4.inOut",
                        duration: 1,
                    });

                    tl.to(
                        items[i - 1],
                        {
                            scale: 0.5,
                            filter: "blur(20px)",
                            ease: "power4.inOut",
                            duration: 1,
                        },
                        "<",
                    );
                    tl.to(
                        item,
                        {
                            scale: 1,
                            filter: "blur(0px)",
                            ease: "power4.inOut",
                            duration: 1,
                        },
                        "<",
                    );
                }

                tl.to(track, {
                    x: () => -(i * getMoveDistance()),
                    duration: 1.5,
                });
            });
        });

        document.addEventListener(
            "astro:before-preparation",
            () => {
                ctx.revert();
            },
            { once: true },
        );

        const endSection = document.getElementById("hs-end-section");
        if (endSection) {
            const observer = new IntersectionObserver(
                (entries) => {
                    if (entries[0].isIntersecting) {
                        observer.disconnect();

                        const swipe = document.getElementById("global-swipe");
                        if (swipe) {
                            gsap.to(swipe, {
                                xPercent: 0,
                                x: 0,
                                duration: 1,
                                ease: "power3.inOut",
                                onComplete: () => {
                                    // swipeClosureTime read by BaseLayout to enforce min hold time on return
                                    sessionStorage.setItem(
                                        "swipeClosureTime",
                                        Date.now().toString(),
                                    );
                                    navigate("/blockmans-den");
                                },
                            });
                        } else {
                            navigate("/blockmans-den");
                        }
                    }
                },
                { threshold: 0.01 },
            );
            observer.observe(endSection);
        }
    });
</script>
