---
import { getImage } from "astro:assets";
import logoImport from "../../assets/images/logo/obc-logo.png";
import loyaltyAppIconImport from "../../assets/images/loyalty-app-icon.png";

const logo = await getImage({ src: logoImport, format: "webp" });
const loyaltyAppIcon = await getImage({
  src: loyaltyAppIconImport,
  format: "webp",
});

const links = [
  { name: "Departments", href: "#" },
  { name: "About Us", href: "/about-us" },
  { name: "Store Finder", href: "/store-finder" },
  { name: "Contact Us", href: "/contact-us" },
  { name: "Blockman's Den", href: "/blockmans-den" },
  { name: "Recipes", href: "/recipes" },
  { name: "Promotions", href: "/#promotions" },
  { name: "Thola Zonke Rewards", href: "/thola-zonke" },
];
---

<header
  class="fixed top-0 left-0 w-full z-[99] text-brand-light font-sans transition-all pt-2 pb-2 duration-300 bg-black/85 backdrop-blur-sm"
>
  <div class="w-full px-4 sm:px-6 lg:px-8 xl:px-12">
    <div class="grid grid-cols-3 items-center h-20 w-full">
      <div class="flex items-center justify-start">
        <button
          id="menu-open-btn"
          class="text-brand-light hover:text-brand-primary focus:outline-none transition-transform hover:scale-105"
        >
          <svg
            class="h-8 w-8"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>

      <div class="flex items-center justify-center">
        <a
          href="/"
          aria-label="OBC Group Logo"
          class="relative group flex items-center justify-center pb-2 sm:pb-3"
        >
          <img
            src={logo.src}
            alt="OBC Group Logo"
            class="h-10 sm:h-12 w-auto object-contain group-hover:scale-105 transition-transform duration-300 block"
          />
        </a>
      </div>

      <div class="flex items-center justify-end">
        <ul>
          <li>
            <a
              href="/thola-zonke"
              class="w-[82px] h-auto flex items-center justify-center transition-colors shadow-md"
              title="Loyalty App"
            >
              <img
                src={loyaltyAppIcon.src}
                alt="Loyalty App"
                class="h-full w-auto object-fill"
              />
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>
</header>

<!-- Mobile Menu Drawer Overlay -->
<div
  id="mobile-menu-overlay"
  class="fixed inset-0 bg-brand-light/10 z-[100] hidden opacity-0 transition-opacity duration-300 backdrop-blur-[3px]"
>
</div>

<!-- Main Mobile Menu Drawer -->
<nav
  id="mobile-menu-drawer"
  class="fixed top-0 left-0 w-full sm:w-100 max-w-md h-dvh bg-brand-dark z-[101] transform -translate-x-full transition-transform duration-300 flex flex-col shadow-2xl border-r border-brand-primary/20"
>
  <div class="flex items-center justify-start h-20 px-4 sm:px-6">
    <button
      id="menu-close-btn"
      class="text-brand-light hover:text-brand-primary focus:outline-none transition-all duration-300 hover:rotate-90 p-2 -ml-2"
      aria-label="Close menu"
    >
      <svg
        class="h-8 w-8"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>

  <div class="flex-1 overflow-y-auto w-full py-4">
    <ul class="flex flex-col w-full px-6">
      {
        links.map((link) => {
          if (link.name === "Departments") {
            return (
              <li class="w-full border-b border-brand-primary last:border-b-0 flex flex-col">
                <button
                  id="dept-accordion-btn"
                  class="flex items-center justify-between py-5 text-brand-light hover:text-brand-primary text-sm font-medium tracking-widest uppercase transition-colors cursor-pointer w-full text-left focus:outline-none group"
                >
                  <span>{link.name}</span>
                  <svg
                    id="dept-accordion-icon"
                    class="w-4 h-4 text-brand-light/50 group-hover:text-brand-primary transition-transform duration-300 transform"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M9 5l7 7-7 7"
                    />
                  </svg>
                </button>
                <div
                  id="dept-accordion-content"
                  class="grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-in-out"
                >
                  <div class="overflow-hidden">
                    <ul class="flex flex-col w-full pl-6 pb-5 space-y-4">
                      {[
                        { name: "Butchery", href: "/butchery" },
                        { name: "Liquor", href: "/liquor" },
                        { name: "Bakery", href: "/bakery" },
                      ].map((sublink) => (
                        <li class="w-full">
                          <a
                            href={sublink.href}
                            class="block text-brand-light/70 hover:text-brand-primary text-[13px] font-medium tracking-widest uppercase transition-colors"
                          >
                            {sublink.name}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>
              </li>
            );
          }

          return (
            <li class="w-full border-b border-brand-primary last:border-b-0">
              <a
                href={link.href}
                class="flex items-center justify-between py-5 text-brand-light hover:text-brand-primary text-sm font-medium tracking-widest uppercase transition-colors group"
              >
                <span>{link.name}</span>
              </a>
            </li>
          );
        })
      }
    </ul>
  </div>
</nav>

<script>
  function setupMenu() {
    const openBtn = document.getElementById("menu-open-btn");
    const closeBtn = document.getElementById("menu-close-btn");
    const overlay = document.getElementById("mobile-menu-overlay");
    const drawer = document.getElementById("mobile-menu-drawer");
    const body = document.body;

    const deptBtn = document.getElementById("dept-accordion-btn");
    const deptContent = document.getElementById("dept-accordion-content");
    const deptIcon = document.getElementById("dept-accordion-icon");

    // Accordion setup
    if (deptBtn && deptContent && deptIcon) {
      deptBtn.addEventListener("click", () => {
        const isOpen = deptContent.classList.contains("grid-rows-[1fr]");

        if (isOpen) {
          deptContent.classList.remove("grid-rows-[1fr]");
          deptContent.classList.add("grid-rows-[0fr]");
          deptIcon.classList.remove("rotate-90");
        } else {
          deptContent.classList.remove("grid-rows-[0fr]");
          deptContent.classList.add("grid-rows-[1fr]");
          deptIcon.classList.add("rotate-90");
        }
      });
    }

    if (!openBtn || !closeBtn || !overlay || !drawer) return;

    const openMenu = () => {
      overlay.classList.remove("hidden");
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          overlay.classList.remove("opacity-0");
          drawer.classList.remove("-translate-x-full");
          body.style.overflow = "hidden";
        });
      });
    };

    const closeMenu = () => {
      overlay.classList.add("opacity-0");
      drawer.classList.add("-translate-x-full");
      body.style.overflow = "";

      // Also reset accordion when menu closes
      if (deptContent && deptIcon) {
        deptContent.classList.remove("grid-rows-[1fr]");
        deptContent.classList.add("grid-rows-[0fr]");
        deptIcon.classList.remove("rotate-90");
      }

      setTimeout(() => {
        overlay.classList.add("hidden");
      }, 300);
    };

    openBtn.addEventListener("click", openMenu);
    closeBtn.addEventListener("click", closeMenu);
    overlay.addEventListener("click", closeMenu);
  }
  // Astro keeps catching me out with this one because of clientRouter/view-transitions
  document.addEventListener("astro:page-load", setupMenu);
</script>
